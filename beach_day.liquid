<style>
  /* Fluid Sizing for TRMNL OG (800x480) & TRMNL X (1872x1404) compatibility */
  .hero-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 5;
    padding: 6cqh 4cqw;
    border-radius: 1.5cqh;
    text-align: center;
    box-sizing: border-box;
    height: 100%;
  }

  .hero-panel--yes {
    background-color: #000000;
    color: #ffffff;
    border: 0.8cqh solid #000000;
  }

  .hero-panel--no,
  .hero-panel--rain {
    background-color: #ffffff;
    color: #000000;
    border: 0.8cqh solid #000000;
  }

  .hero-icon {
    width: 28cqh;
    height: 28cqh;
    margin-bottom: 4cqh;
  }

  .hero-title {
    font-size: 11cqh;
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.4cqw;
  }

  .hero-subtitle {
    font-size: 4.2cqh;
    margin-top: 2cqh;
    opacity: 0.8;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2cqw;
  }

  .details-panel {
    display: flex;
    flex-direction: column;
    flex: 7;
    padding: 6cqh 5cqw;
    box-sizing: border-box;
    background-color: #ffffff;
    border: 0.8cqh solid #000000;
    border-radius: 1.5cqh;
    height: 100%;
  }

  .details-header {
    font-size: 4.5cqh;
    font-weight: 800;
    border-bottom: 0.8cqh solid #000000;
    padding-bottom: 1.5cqh;
    margin-bottom: 1cqh;
    text-transform: uppercase;
    letter-spacing: 0.2cqw;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .conditions-table {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: space-between;
    margin-top: 2cqh;
  }

  .condition-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 2cqh 1cqw;
    border-bottom: 0.2cqh dashed #000000;
    flex: 1;
  }

  .condition-row:last-child {
    border-bottom: none;
  }

  .condition-info {
    display: flex;
    flex-direction: column;
    flex: 1;
    justify-content: center;
  }

  .condition-name {
    font-size: 3.8cqh;
    font-weight: 700;
    color: #000000;
    line-height: 1.1;
  }

  .condition-threshold {
    font-size: 2.7cqh;
    color: #555555;
    margin-top: 0.4cqh;
    font-weight: 500;
    line-height: 1.1;
  }

  .condition-value {
    font-size: 4.2cqh;
    font-weight: 800;
    text-align: right;
    margin-right: 2cqw;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    line-height: 1;
  }

  .condition-status {
    width: 6cqh;
    height: 6cqh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .status-icon {
    width: 5cqh;
    height: 5cqh;
  }

  .status-icon--pass {
    color: #000000;
  }

  .status-icon--fail {
    color: #888888;
    stroke-dasharray: 4;
  }
</style>

<!-- Liquid Conditional Evaluation Logic -->
{% assign offset = trmnl.user.utc_offset | default: -25200 %}
{% assign temp = temperatureHi | default: temperature_hi | default: temperature | plus: 0 %}
{% assign precip = probabilityofPrecipitation | default: probablityofPrecipitation | default: probability_of_precipitation | default: precipitation | plus: 0 %}
{% assign wind = windspeedHi | default: wind_speed_hi | default: wind_speed | plus: 0 %}
{% assign forecast_val = detailedForecast | default: detailed_forecast | default: forecast %}
{% comment %} We will parse the raw hourly data below to calculate clearing times dynamically {% endcomment %}


{% comment %} Determine current time dynamically from the device update timestamp {% endcomment %}
{% assign time_source = "now" %}

{% comment %} Parse sunrise and sunset values to minutes of the day {% endcomment %}
{% assign sunrise_str = sunrise | append: "" %}
{% assign sunrise_parts = sunrise_str | split: " " %}
{% assign sunrise_time_part = "" %}
{% assign sunrise_ampm_part = "" %}
{% for part in sunrise_parts %}
  {% if part contains ":" %}
    {% assign sunrise_time_part = part %}
  {% endif %}
  {% assign part_lower = part | downcase %}
  {% if part_lower == "am" or part_lower == "pm" %}
    {% assign sunrise_ampm_part = part_lower %}
  {% endif %}
{% endfor %}
{% if sunrise_time_part != "" %}
  {% assign sunrise_time_parts = sunrise_time_part | split: ":" %}
  {% assign sunrise_h = sunrise_time_parts[0] | plus: 0 %}
  {% assign sunrise_m = sunrise_time_parts[1] | plus: 0 %}
  {% if sunrise_ampm_part == "pm" and sunrise_h < 12 %}
    {% assign sunrise_h = sunrise_h | plus: 12 %}
  {% elsif sunrise_ampm_part == "am" and sunrise_h == 12 %}
    {% assign sunrise_h = 0 %}
  {% endif %}
  {% assign sunrise_val = sunrise_h | times: 60 | plus: sunrise_m %}
{% else %}
  {% assign sunrise_num = sunrise | plus: 0 %}
  {% if sunrise_num > 86400 %}
    {% assign sunrise_local = sunrise_num | plus: offset %}
    {% assign sunrise_h = sunrise_local | date: "%H" | plus: 0 %}
    {% assign sunrise_m = sunrise_local | date: "%M" | plus: 0 %}
    {% assign sunrise_val = sunrise_h | times: 60 | plus: sunrise_m %}
  {% else %}
    {% assign sunrise_val = sunrise_num %}
  {% endif %}
{% endif %}

{% assign sunset_str = sunset | append: "" %}
{% assign sunset_parts = sunset_str | split: " " %}
{% assign sunset_time_part = "" %}
{% assign sunset_ampm_part = "" %}
{% for part in sunset_parts %}
  {% if part contains ":" %}
    {% assign sunset_time_part = part %}
  {% endif %}
  {% assign part_lower = part | downcase %}
  {% if part_lower == "am" or part_lower == "pm" %}
    {% assign sunset_ampm_part = part_lower %}
  {% endif %}
{% endfor %}
{% if sunset_time_part != "" %}
  {% assign sunset_time_parts = sunset_time_part | split: ":" %}
  {% assign sunset_h = sunset_time_parts[0] | plus: 0 %}
  {% assign sunset_m = sunset_time_parts[1] | plus: 0 %}
  {% if sunset_ampm_part == "pm" and sunset_h < 12 %}
    {% assign sunset_h = sunset_h | plus: 12 %}
  {% elsif sunset_ampm_part == "am" and sunset_h == 12 %}
    {% assign sunset_h = 0 %}
  {% endif %}
  {% assign sunset_val = sunset_h | times: 60 | plus: sunset_m %}
{% else %}
  {% assign sunset_num = sunset | plus: 0 %}
  {% if sunset_num > 86400 %}
    {% assign sunset_local = sunset_num | plus: offset %}
    {% assign sunset_h = sunset_local | date: "%H" | plus: 0 %}
    {% assign sunset_m = sunset_local | date: "%M" | plus: 0 %}
    {% assign sunset_val = sunset_h | times: 60 | plus: sunset_m %}
  {% else %}
    {% assign sunset_val = sunset_num %}
  {% endif %}
{% endif %}

{% comment %} Parse current local time from the device update timestamp and timezone offset {% endcomment %}
{% assign local_time_epoch = time_source | date: "%s" | plus: offset %}
{% assign time_h = local_time_epoch | date: "%H" | plus: 0 %}
{% assign time_m = local_time_epoch | date: "%M" | plus: 0 %}
{% assign time_val = time_h | times: 60 | plus: time_m %}

{% comment %} Sunset limit is 60 minutes before sunset {% endcomment %}
{% assign sunset_limit = sunset_val | minus: 60 %}

{% comment %} Time check {% endcomment %}
{% assign cond_time = false %}
{% if sunrise_val == 0 or sunset_val == 0 %}
  {% assign cond_time = true %}
{% else %}
  {% if time_val >= sunrise_val and time_val <= sunset_limit %}
    {% assign cond_time = true %}
  {% endif %}
{% endif %}

{% comment %} Determine if it is night time {% endcomment %}
{% assign is_night_time = false %}
{% if cond_time == false %}
  {% assign is_night_time = true %}
{% endif %}

{% comment %} Calculate clearing variables dynamically from hourly payload {% endcomment %}
{% assign sun_hours = 0 %}
{% assign is_clearing_later = "false" %}
{% assign clearing_time = "" %}
{% assign first_sunny_hour = -1 %}
{% assign first_period_checked = false %}
{% assign is_currently_sunny = "false" %}
{% assign today_date = local_time_epoch | date: "%Y-%m-%d" %}
{% assign tomorrow_date = local_time_epoch | plus: 86400 | date: "%Y-%m-%d" %}

{% if is_night_time %}
  {% assign target_date = tomorrow_date %}
{% else %}
  {% assign target_date = today_date %}
{% endif %}

{% for period in hourly %}
  {% if period.t contains target_date %}
    {% assign parts = period.t | split: "T" %}
    {% assign hour = parts[1] | plus: 0 %}

    {% if hour >= 9 and hour <= 18 %}
      {% assign fc_lower = period.f | downcase %}
      {% assign is_sunny = false %}
      {% if fc_lower contains "sunny" or fc_lower contains "clear" or fc_lower contains "sun" %}
        {% assign is_sunny = true %}
      {% endif %}

      {% if is_sunny %}
        {% assign sun_hours = sun_hours | plus: 1 %}
        {% if first_sunny_hour == -1 %}
          {% assign first_sunny_hour = hour %}
        {% endif %}
      {% endif %}

      {% if first_period_checked == false %}
        {% if is_sunny %}
          {% assign is_currently_sunny = "true" %}
        {% endif %}
        {% assign first_period_checked = true %}
      {% endif %}
    {% endif %}
  {% endif %}
{% endfor %}

{% if sun_hours > 0 %}
  {% if first_sunny_hour != -1 %}
    {% assign ampm = "AM" %}
    {% assign display_hour = first_sunny_hour %}
    {% if first_sunny_hour >= 12 %}
      {% assign ampm = "PM" %}
      {% if first_sunny_hour > 12 %}
        {% assign display_hour = first_sunny_hour | minus: 12 %}
      {% endif %}
    {% elsif first_sunny_hour == 0 %}
      {% assign display_hour = 12 %}
    {% endif %}
    {% assign clearing_time = display_hour | append: " " | append: ampm %}
    
    {% if is_currently_sunny == "false" %}
      {% assign is_clearing_later = "true" %}
    {% endif %}
  {% endif %}
{% endif %}

{% assign is_sunny_later = "false" %}
{% if sun_hours > 0 %}
  {% assign is_sunny_later = "true" %}
{% endif %}

{% comment %} Evaluate condition rules {% endcomment %}
{% assign cond_temp = false %}
{% if temp >= 75 %}
  {% assign cond_temp = true %}
{% endif %}

{% assign cond_precip = false %}
{% if precip < 20.0 %}
  {% assign cond_precip = true %}
{% endif %}

{% assign cond_wind = false %}
{% if wind <= 15.0 %}
  {% assign cond_wind = true %}
{% endif %}

{% comment %} Forecast check {% endcomment %}
{% assign cond_forecast = false %}
{% assign forecast_lower = forecast_val | downcase %}
{% if forecast_lower contains "sunny" or forecast_lower contains "clear" or is_sunny_later == "true" %}
  {% assign cond_forecast = true %}
{% endif %}

{% comment %} Determine 6 distinct states {% endcomment %}

{% comment %} State 1: Beach Day {% endcomment %}
{% assign is_beach_day = false %}
{% if cond_temp and cond_precip and cond_wind and cond_forecast and cond_time %}
  {% assign is_beach_day = true %}
{% endif %}

{% comment %} State 2: Night Time (handled above) {% endcomment %}

{% if is_night_time %}
  {% assign temp = tomorrowTemperature | default: tomorrow_temperature | plus: 0 %}
  {% assign precip = tomorrowProbabilityOfPrecipitation | default: tomorrow_probability_of_precipitation | plus: 0 %}
  {% assign wind = tomorrowWindSpeedHi | default: tomorrow_wind_speed_hi | default: tomorrow_wind_speed | plus: 0 %}
  {% assign forecast_val = tomorrowDetailedForecast | default: tomorrow_detailed_forecast %}

  {% comment %} Recalculate condition rules for tomorrow {% endcomment %}
  {% assign cond_temp = false %}
  {% if temp >= 75 %}
    {% assign cond_temp = true %}
  {% endif %}

  {% assign cond_precip = false %}
  {% if precip < 20.0 %}
    {% assign cond_precip = true %}
  {% endif %}

  {% assign cond_wind = false %}
  {% if wind <= 15.0 %}
    {% assign cond_wind = true %}
  {% endif %}

  {% assign cond_forecast = false %}
  {% assign forecast_lower = forecast_val | downcase %}
  {% if forecast_lower contains "sunny" or forecast_lower contains "clear" or is_sunny_later == "true" %}
    {% assign cond_forecast = true %}
  {% endif %}
{% endif %}

{% comment %} State 3: Rainy Day {% endcomment %}
{% assign is_rain_day = false %}
{% if is_beach_day == false and is_night_time == false %}
  {% if precip >= 40 %}
    {% assign is_rain_day = true %}
  {% endif %}
{% endif %}

{% comment %} State 4: Windy Day {% endcomment %}
{% assign is_windy_day = false %}
{% if is_beach_day == false and is_night_time == false and is_rain_day == false %}
  {% if cond_wind == false %}
    {% assign is_windy_day = true %}
  {% endif %}
{% endif %}

{% comment %} State 5: Chilly Day {% endcomment %}
{% assign is_chilly_day = false %}
{% if is_beach_day == false and is_night_time == false and is_rain_day == false and is_windy_day == false %}
  {% if temp < 65 %}
    {% assign is_chilly_day = true %}
  {% endif %}
{% endif %}

{% comment %} State 5.5: Nice Day {% endcomment %}
{% assign is_nice_day = false %}
{% if is_beach_day == false and is_night_time == false and is_rain_day == false and is_windy_day == false %}
  {% if temp >= 65 and temp < 75 and cond_forecast == true %}
    {% assign is_nice_day = true %}
  {% endif %}
{% endif %}

{% comment %} State 6: Grey Day {% endcomment %}
{% assign is_grey_day = false %}
{% if is_beach_day == false and is_night_time == false and is_rain_day == false and is_windy_day == false and is_chilly_day == false and is_nice_day == false %}
  {% if cond_forecast == false %}
    {% assign is_grey_day = true %}
  {% endif %}
{% endif %}

{% comment %} Format time display strings {% endcomment %}
{% if sunrise_val == 0 or sunset_val == 0 %}
  {% assign time_str = "Always" %}
{% else %}
  {% assign time_str = local_time_epoch | date: "%I:%M %p" %}
{% endif %}

{% comment %} Calculate sunlight / night hours and format times {% endcomment %}
{% if sunrise_val > 0 and sunset_val > 0 %}
  {% if time_val >= sunrise_val and time_val < sunset_val %}
    {% assign minutes_left = sunset_val | minus: time_val %}
    {% assign hours_left = minutes_left | divided_by: 60.0 | floor %}
  {% else %}
    {% if time_val >= sunset_val %}
      {% assign minutes_until_sunrise = 1440 | minus: time_val | plus: sunrise_val %}
    {% else %}
      {% assign minutes_until_sunrise = sunrise_val | minus: time_val %}
    {% endif %}
    {% assign hours_until_sunrise = minutes_until_sunrise | divided_by: 60.0 | floor %}
  {% endif %}

  {% comment %} Format Sunrise Time {% endcomment %}
  {% assign sr_h = sunrise_val | divided_by: 60 %}
  {% assign sr_m = sunrise_val | modulo: 60 %}
  {% assign sr_ampm = "AM" %}
  {% if sr_h >= 12 %}
    {% assign sr_ampm = "PM" %}
    {% if sr_h > 12 %}
      {% assign sr_h = sr_h | minus: 12 %}
    {% endif %}
  {% elsif sr_h == 0 %}
    {% assign sr_h = 12 %}
  {% endif %}
  {% if sr_m < 10 %}
    {% assign sr_m_str = "0" | append: sr_m %}
  {% else %}
    {% assign sr_m_str = sr_m %}
  {% endif %}
  {% assign sunrise_formatted = sr_h | append: ":" | append: sr_m_str | append: " " | append: sr_ampm %}

  {% comment %} Format Sunset Time {% endcomment %}
  {% assign ss_h = sunset_val | divided_by: 60 %}
  {% assign ss_m = sunset_val | modulo: 60 %}
  {% assign ss_ampm = "AM" %}
  {% if ss_h >= 12 %}
    {% assign ss_ampm = "PM" %}
    {% if ss_h > 12 %}
      {% assign ss_h = ss_h | minus: 12 %}
    {% endif %}
  {% elsif ss_h == 0 %}
    {% assign ss_h = 12 %}
  {% endif %}
  {% if ss_m < 10 %}
    {% assign ss_m_str = "0" | append: ss_m %}
  {% else %}
    {% assign ss_m_str = ss_m %}
  {% endif %}
  {% assign sunset_formatted = ss_h | append: ":" | append: ss_m_str | append: " " | append: ss_ampm %}
{% endif %}

{% capture sun_left_str %}
  {% if sunrise_val == 0 or sunset_val == 0 %}
    Always
  {% elsif time_val >= sunrise_val and time_val < sunset_val %}
    {% if hours_left > 0 %}
      {{ hours_left }} hour{% if hours_left != 1 %}s{% endif %} left
    {% else %}
      {{ minutes_left }} minute{% if minutes_left != 1 %}s{% endif %} left
    {% endif %}
  {% else %}
    {% if hours_until_sunrise > 0 %}
      {{ hours_until_sunrise }} hour{% if hours_until_sunrise != 1 %}s{% endif %} until sun
    {% else %}
      {{ minutes_until_sunrise }} minute{% if minutes_until_sunrise != 1 %}s{% endif %} until sun
    {% endif %}
  {% endif %}
{% endcapture %}
{% assign sun_left_str = sun_left_str | strip %}

{% capture time_meta %}
  {% if sunrise_val == 0 or sunset_val == 0 %}
    Always
  {% elsif time_val >= sunrise_val and time_val < sunset_val %}
    {% assign hours_until_sunset = minutes_left | divided_by: 60.0 | ceil %}
    {{ hours_until_sunset }} hour{% if hours_until_sunset != 1 %}s{% endif %} until {{ sunset_formatted }} sunset
  {% else %}
    Sunrise at {{ sunrise_formatted }}
  {% endif %}
{% endcapture %}
{% assign time_meta = time_meta | strip %}

<div class="layout layout--row gap--medium" style="height: 100%;">
  
  <!-- Left Side: Hero Banner -->
  {% if is_beach_day %}
    <div class="hero-panel hero-panel--yes">
      <!-- Sunny Beach SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="10" r="4" fill="#ffffff" />
        <path d="M12 2v2M12 16v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 10h2M20 10h2M6.34 15.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        <path d="M2 20c4-1 6-1 10 0s6 1 10 0" stroke-width="2" />
        <path d="M2 22c4-1 6-1 10 0s6 1 10 0" stroke-width="2" />
      </svg>
      <div class="hero-title">Beach<br/>Day!</div>
       <div class="hero-subtitle">Pack the car</div>
    </div>
  {% elsif is_night_time %}
    <div class="hero-panel hero-panel--no">
      <!-- Crescent Moon SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
      <div class="hero-title">Night<br/>Time</div>
      <div class="hero-subtitle">Beach is closed</div>
    </div>
  {% elsif is_rain_day %}
    <div class="hero-panel hero-panel--no">
      <!-- Rain Cloud SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 18.6a6 6 0 1 0-8.2-8.2 6 6 0 0 0-3.3 11H17a4 4 0 1 0 0-8h-.3" />
        <line x1="12" y1="18" x2="12" y2="22" stroke-width="2" />
        <line x1="8" y1="18" x2="8" y2="22" stroke-width="2" />
        <line x1="16" y1="18" x2="16" y2="22" stroke-width="2" />
      </svg>
      <div class="hero-title">Rain<br/>Day</div>
      <div class="hero-subtitle">Stay dry</div>
    </div>
  {% elsif is_windy_day %}
    <div class="hero-panel hero-panel--no">
      <!-- Wind lines SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2.5 2.5 0 1 1 19.5 12H2" />
      </svg>
      <div class="hero-title">Wind<br/>Day</div>
      <div class="hero-subtitle">Hold your towel</div>
    </div>
  {% elsif is_chilly_day %}
    <div class="hero-panel hero-panel--no">
      <!-- Cloudy (Chilly Day) SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 18.6a6 6 0 1 0-8.2-8.2 6 6 0 0 0-3.3 11H17a4 4 0 1 0 0-8h-.3" />
      </svg>
      <div class="hero-title">Brrr<br/>Day</div>
      <div class="hero-subtitle">Wear a hoodie</div>
    </div>
  {% elsif is_nice_day %}
    <div class="hero-panel hero-panel--no">
      {% if is_clearing_later == "true" %}
        <!-- Cloud-Sun SVG Icon -->
        <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2v2"/>
          <path d="m4.93 4.93 1.41 1.41"/>
          <path d="M20 12h2"/>
          <path d="m19.07 4.93-1.41 1.41"/>
          <path d="M15.947 12.65a4 4 0 0 0-5.925-4.128"/>
          <path d="M13 22H7a5 5 0 1 1 4.9-6H13a3 3 0 0 1 0 6Z"/>
        </svg>
      {% else %}
        <!-- Sun SVG Icon -->
        <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      {% endif %}
      <div class="hero-title">Nice<br/>Day</div>
      <div class="hero-subtitle">But not quite beachy</div>
    </div>
  {% elsif is_grey_day %}
    <div class="hero-panel hero-panel--no">
      <!-- Overlapping Clouds SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 18.6a6 6 0 1 0-8.2-8.2 6 6 0 0 0-3.3 11H17a4 4 0 1 0 0-8h-.3" />
        <path d="M22 15a4 4 0 0 0-3.3-3.9 4.5 4.5 0 0 0-8.2-3.8 5 5 0 0 0-2.5 6.7" />
      </svg>
      <div class="hero-title">Grey<br/>Day</div>
      <div class="hero-subtitle">Seattle vibes</div>
    </div>
  {% else %}
    <div class="hero-panel hero-panel--no">
      <!-- Default fallback: Simple Cloud SVG Icon -->
      <svg class="hero-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 18.6a6 6 0 1 0-8.2-8.2 6 6 0 0 0-3.3 11H17a4 4 0 1 0 0-8h-.3" />
      </svg>
      <div class="hero-title">Just A<br/>Day</div>
      <div class="hero-subtitle">Not beachy</div>
    </div>
  {% endif %}

  <div class="details-panel">
    <div class="details-header" style="display: flex; flex-direction: column; align-items: flex-start;">
      <div style="display: flex; justify-content: space-between; align-items: baseline; width: 100%;">
        {% if is_night_time %}
          {% assign tomorrow_epoch = local_time_epoch | plus: 86400 %}
          <span style="font-size: 4.5cqh; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2cqw; white-space: nowrap;">Tomorrow ({{ tomorrow_epoch | date: "%A" }})</span>
        {% else %}
          <span style="font-size: 4.5cqh; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2cqw; white-space: nowrap;">{{ local_time_epoch | date: "%A" }}</span>
        {% endif %}
      </div>
      {% if forecast_val != blank %}
        <div style="font-size: 2.2cqh; font-weight: 500; text-transform: none; letter-spacing: 0; width: 100%; opacity: 0.85; margin-top: 1cqh; line-height: 1.25; text-align: left;">
          {{ forecast_val }}
        </div>
      {% endif %}
    </div>

    <div class="conditions-table">
      
      <!-- Temperature -->
      <div class="condition-row">
        <div class="condition-info">
          <span class="condition-name">High Temp</span>
          <span class="condition-threshold">above 75&deg;F?</span>
        </div>
        <span class="condition-value">{{ temp }}&deg;F</span>
        <div class="condition-status">
          {% if cond_temp %}
            <!-- Pass Checkmark SVG -->
            <svg class="status-icon status-icon--pass" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          {% else %}
            <!-- Fail Cross SVG -->
            <svg class="status-icon status-icon--fail" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          {% endif %}
        </div>
      </div>

      <!-- Precipitation -->
      <div class="condition-row">
        <div class="condition-info">
          <span class="condition-name">Rain Chance</span>
          <span class="condition-threshold">below 20%?</span>
        </div>
        <span class="condition-value">{{ precip }}%</span>
        <div class="condition-status">
          {% if cond_precip %}
            <svg class="status-icon status-icon--pass" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          {% else %}
            <svg class="status-icon status-icon--fail" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          {% endif %}
        </div>
      </div>

      <!-- Wind Speed -->
      <div class="condition-row">
        <div class="condition-info">
          <span class="condition-name">Max Wind</span>
          <span class="condition-threshold">below 15 mph?</span>
        </div>
        <span class="condition-value">{{ wind }} mph</span>
        <div class="condition-status">
          {% if cond_wind %}
            <svg class="status-icon status-icon--pass" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          {% else %}
            <svg class="status-icon status-icon--fail" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          {% endif %}
        </div>
      </div>

      {% capture sun_left_str %}
        {% if sunrise_val == 0 or sunset_val == 0 %}
          Always
        {% elsif time_val >= sunrise_val and time_val < sunset_val %}
          {% if hours_left > 0 %}
            {{ hours_left }} hour{% if hours_left != 1 %}s{% endif %} left
          {% else %}
            {{ minutes_left }} minute{% if minutes_left != 1 %}s{% endif %} left
          {% endif %}
        {% else %}
          {% if hours_until_sunrise > 0 %}
            {{ hours_until_sunrise }} hour{% if hours_until_sunrise != 1 %}s{% endif %} until sun
          {% else %}
            {{ minutes_until_sunrise }} minute{% if minutes_until_sunrise != 1 %}s{% endif %} until sun
          {% endif %}
        {% endif %}
      {% endcapture %}
      {% assign sun_left_str = sun_left_str | strip %}

      <!-- Sun Check -->
      <div class="condition-row">
        <div class="condition-info">
          <span class="condition-name">Sun</span>
          <span class="condition-threshold">coming out?</span>
        </div>
        <span class="condition-value">
          {% if is_clearing_later == "true" and clearing_time != blank %}
            At {{ clearing_time }}
          {% elsif cond_forecast %}
            All day
          {% else %}
            Cloudy
          {% endif %}
        </span>
        <div class="condition-status">
          {% if cond_forecast %}
            <svg class="status-icon status-icon--pass" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
          {% else %}
            <svg class="status-icon status-icon--fail" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
            </svg>
          {% endif %}
        </div>
      </div>

    </div>

    <!-- Bottom Divider & Sunset Info -->
    <div style="border-top: 0.8cqh solid #000000; margin-top: 1cqh; padding-top: 1.5cqh; text-align: center;">
      <span style="font-size: 2.7cqh; font-weight: 700; color: #555555; white-space: nowrap;">
        {{ time_meta }}
      </span>
    </div>
  </div>

</div>
